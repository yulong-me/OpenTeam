{
  "name": "opencouncil",
  "private": true,
  "version": "0.1.0",
  "description": "Custom agent councils for real work.",
  "author": "Yulong",
  "main": "desktop/main.cjs",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0 <26",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "node:check": "node scripts/check-node-version.mjs",
    "predev": "pnpm run node:check",
    "dev": "node scripts/dev.mjs",
    "predev:gateway": "pnpm run node:check",
    "dev:gateway": "node scripts/dev-gateway.mjs",
    "dev:backend": "pnpm --dir backend dev",
    "dev:frontend": "pnpm --dir frontend dev",
    "prestart": "pnpm run node:check",
    "start": "node scripts/start.mjs",
    "prebuild": "pnpm run node:check",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:backend": "pnpm --dir backend build",
    "build:frontend": "pnpm --dir frontend build",
    "desktop:preflight": "node scripts/desktop-release-preflight.mjs",
    "desktop:prepare-frontend-standalone": "node scripts/prepare-frontend-standalone.mjs",
    "desktop:rebuild-native": "node scripts/rebuild-desktop-native.mjs",
    "desktop:verify-artifacts": "node scripts/verify-desktop-artifacts.mjs",
    "desktop:dev": "pnpm build && pnpm run desktop:rebuild-native && electron desktop/main.cjs",
    "desktop:pack": "node scripts/build-desktop.mjs pack",
    "desktop:dist": "node scripts/build-desktop.mjs dist-local",
    "desktop:dist:local": "node scripts/build-desktop.mjs dist-local",
    "desktop:dist:mac-local-update": "node scripts/build-mac-local-update.mjs",
    "desktop:serve:mac-update": "node scripts/serve-desktop-update-feed.mjs",
    "desktop:publish": "node scripts/build-desktop.mjs publish",
    "test:node-version": "node tests/check-node-version.test.mjs",
    "test:better-sqlite-native": "node tests/ensure-better-sqlite.test.mjs",
    "test:desktop-launcher": "node tests/desktop-launcher.test.mjs",
    "install:all": "pnpm -r install"
  },
  "build": {
    "appId": "me.yulong.opencouncil",
    "productName": "OpenCouncil",
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yulong-me",
        "repo": "OpenCouncil"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      "desktop/**/*",
      ".agents/skills/**/*",
      "backend/dist/**/*",
      "backend/package.json",
      "backend/node_modules/**/*",
      "frontend/.next/standalone/**/*"
    ],
    "asar": false,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^8.2.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  }
}
